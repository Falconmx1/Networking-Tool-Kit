# Networking Tool Kit - Red Mx Configuration File
# ================================================

# Auto-update settings
AUTO_UPDATE=true
UPDATE_CHECK_INTERVAL=86400  # segundos (24 horas)

# Logging settings
ENABLE_LOGGING=true
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR
LOG_FILE="logs/activity.log"
MAX_LOG_SIZE_MB=10

# Behavior
SHOW_BANNER=true
CONFIRM_EXIT=true
COLORED_OUTPUT=true

# Version
VERSION="2.1.0"
